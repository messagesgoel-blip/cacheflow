{
  "name": "cacheflow-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "test": "jest --runInBand",
    "plasmic:init": "npx @plasmicapp/cli init --enable-skip-auth --platform nextjs --code-lang ts --code-scheme blackbox --src-dir . --plasmic-dir ./plasmic --yes",
    "plasmic:status": "bash -lc 'npx @plasmicapp/cli status --config \"$PWD/plasmic.json\"'",
    "plasmic:sync": "bash -lc 'npx @plasmicapp/cli sync --config \"$PWD/plasmic.json\" --yes'",
    "plasmic:watch": "bash -lc 'npx @plasmicapp/cli watch --config \"$PWD/plasmic.json\"'",
    "plasmic:sync:project": "bash -lc 'PROJECT_ID=\"${PLASMIC_PROJECT_ID:-dBrwTrDKiTkBShUoNHTaNj}\"; npx @plasmicapp/cli sync --config \"$PWD/plasmic.json\" --projects \"$PROJECT_ID\" --yes'"
  },
  "dependencies": {
    "@plasmicapp/react-web": "^0.2.426",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ssh2": "^1.15.5",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.542.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.25",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
