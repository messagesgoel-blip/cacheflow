{
  "id": null,
  "uid": "cacheflow-manager",
  "title": "CacheFlow Manager Overview",
  "tags": [
    "cacheflow",
    "manager",
    "roadmap",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Manager Summary",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "# CacheFlow Manager Overview\n- Current execution: Sprint 7 / Version 2 planning\n- Audience: quick product and execution status at a glance\n- Source of truth: `docs/roadmap.md`, `logs/orchestrator-state.json`, and generated metrics"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Sprint",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_current_sprint",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Version 1 Progress %",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_roadmap_version_progress_percent{roadmap_version=\"1\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Version 2 Progress %",
      "gridPos": {
        "x": 9,
        "y": 4,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_roadmap_version_progress_percent{roadmap_version=\"2\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Tasks",
      "gridPos": {
        "x": 14,
        "y": 4,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_task_status{status=~\"running|under_review\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Completed Tasks",
      "gridPos": {
        "x": 19,
        "y": 4,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_tasks_completed_total",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Version 2 Open Items",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_roadmap_item_status{roadmap_version=\"2\",status=~\"planned|pending|running|under_review\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Release Gates Cleared",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(cacheflow_gate_is_done)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Current Sprint Progress %",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_sprint_progress",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Recent Changes Logged",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_history_entry)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Roadmap Stage Status",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "cacheflow_roadmap_stage_status",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsUS"
              },
              {
                "id": "custom.align",
                "value": "auto"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsUS"
              },
              {
                "id": "custom.align",
                "value": "auto"
