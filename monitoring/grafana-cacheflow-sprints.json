{
  "dashboard": {
    "id": null,
    "uid": "cacheflow-sprints",
    "title": "CacheFlow Sprint & Gate Tracker",
    "tags": [
      "cacheflow",
      "sprint",
      "gate"
    ],
    "timezone": "browser",
    "schemaVersion": 41,
    "version": 3,
    "refresh": "30s",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "text",
        "title": "Total Roadmap",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 3
        },
        "options": {
          "mode": "markdown",
          "content": "# Total Roadmap\nSprint panels below track progress, commits, and task-level execution state with commit/date/changelog labels."
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "📍 Active Sprint",
        "gridPos": {
          "x": 0,
          "y": 3,
          "w": 4,
          "h": 3
        },
        "targets": [
          {
            "expr": "cacheflow_current_sprint",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        }
      },
      {
        "id": 3,
        "type": "gauge",
        "title": "📈 Roadmap Progress %",
        "gridPos": {
          "x": 4,
          "y": 3,
          "w": 4,
          "h": 3
        },
        "targets": [
          {
            "expr": "100 * cacheflow_tasks_completed_total / clamp_min(cacheflow_total_tasks, 1)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "🟡 Under Execution Tasks",
        "gridPos": {
          "x": 8,
          "y": 3,
          "w": 4,
          "h": 3
        },
        "targets": [
          {
            "expr": "count(cacheflow_task_status{status=\"running\"})",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "type": "stat",
        "title": "✅ Completed Tasks",
        "gridPos": {
          "x": 12,
          "y": 3,
          "w": 4,
          "h": 3
        },
        "targets": [
          {
            "expr": "count(cacheflow_task_status{status=\"done\"})",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "type": "stat",
        "title": "📦 Total Commits",
        "gridPos": {
          "x": 20,
          "y": 3,
          "w": 4,
          "h": 3
        },
        "targets": [
          {
            "expr": "sum(cacheflow_sprint_commits_total)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "type": "gauge",
        "title": "Sprint 0 Progress",
        "gridPos": {
          "x": 0,
          "y": 14,
          "w": 6,
          "h": 3
        },
        "targets": [
          {
            "expr": "cacheflow_sprint_progress_percent{sprint=\"0\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 11,
        "type": "stat",
        "title": "Sprint 0 Total Commits",
        "gridPos": {
          "x": 6,
          "y": 14,
          "w": 6,
          "h": 3
        },
        "targets": [
