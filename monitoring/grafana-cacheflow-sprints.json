  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Canonical Roadmap",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "# CacheFlow Canonical Roadmap\n- Primary product sequence: Version 1, then Version 2\n- Current execution: Sprint 6 / Version 1\n- Legacy Sprint 0-5 details are no longer the primary dashboard surface\n- Source of truth: `docs/roadmap.md` and `logs/orchestrator-state.json`"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Sprint",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_current_sprint",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
