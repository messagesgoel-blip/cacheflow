{
  "id": null,
  "uid": "cacheflow-history",
  "title": "CacheFlow Canonical Roadmap History",
  "tags": [
    "cacheflow",
    "roadmap",
    "history"
  ],
  "schemaVersion": 41,
  "version": 5,
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Scope & Overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "# CacheFlow Roadmap History\n- Focused on current roadmap execution, not a raw dump of every legacy task row\n- Detailed raw task rows are scoped to Sprint 6\n- Historical core-platform audit remains on the separate module audit dashboard"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Core Platform Tasks Done (V1-1)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_task_status{roadmap_stage=\"V1-1\",status=\"done\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sprint 6 Gate Rows Total",
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_task_status{sprint=\"6\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sprint 6 Outstanding Rows",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_task_status{sprint=\"6\",status=~\"planned|pending|running|under_review\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total History Entries",
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(cacheflow_history_entry)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Recent State Changes",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "expr": "cacheflow_history_entry",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsUS"
              },
              {
                "id": "custom.align",
                "value": "auto"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsUS"
              },
              {
                "id": "custom.align",
                "value": "auto"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "__name__"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Name"
              },
              {
                "id": "custom.align",
                "value": "left"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Stage Status"
              },
              {
                "id": "custom.align",
                "value": "center"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "roadmap_version"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Version"
              },
              {
                "id": "custom.align",
                "value": "center"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
