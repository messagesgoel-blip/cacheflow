      "id": 1,
      "type": "text",
      "title": "Execution Board",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "# CacheFlow Detailed Execution Board\n- Current execution: Sprint 7 / Version 2 planning\n- Audience: operators and engineers\n- Covers roadmap items, task detail, change history, and audit exceptions"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Sprint",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_current_sprint",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
