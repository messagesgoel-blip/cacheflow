      "id": 1,
      "type": "text",
      "title": "Scope & Overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "# CacheFlow V1-1 Core Platform Audit\n- Historical completeness audit for the delivered Sprint 0-5 core platform\n- This dashboard is archival detail, not the active Sprint 6 execution board\n- Current roadmap execution lives on the canonical roadmap dashboards"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Modules (V1-1)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "cacheflow_module_audit_total{scope=\"sprints_0_5\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
