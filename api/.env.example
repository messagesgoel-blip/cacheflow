# API Configuration

PORT=8100
DATABASE_URL=postgres://user:password@localhost:5432/cacheflow
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Security: Mandatory 64-character hex string (32 bytes)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# QA Seeding (dev only)
QA_SEED_ENABLED=true

