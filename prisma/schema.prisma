// Prisma Schema for CacheFlow
// Gate: AUTH-2, TRANSFER-1, VAULT-1
// Task: 0.3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  quotaBytes BigInt   @default(107374182400) // 100GB
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  files     File[]
  conflicts Conflict[]
  notifications AdminNotification[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id              String    @id @default(uuid())
  // DB also enforces UNIQUE (LOWER(email)) via SQL migration 007_users_email_lower_unique.
  email           String    @unique
  passwordHash    String    @map("password_hash")
  tenantId        String?   @map("tenant_id") @default("00000000-0000-0000-0000-000000000001")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  quotaBytes      BigInt    @default(10737418240) @map("quota_bytes") // 10GB
  usedBytes       BigInt    @default(0) @map("used_bytes")

  // 2FA (2FA-1)
  twoFactorEnabled    Boolean?  @default(false) @map("two_factor_enabled")
  twoFactorSecret     Bytes?    @map("two_factor_secret")
  twoFactorBackupCodes String[] @map("two_factor_backup_codes")
  twoFactorEnabledAt  DateTime? @map("two_factor_enabled_at")
  twoFactorDisabledAt DateTime? @map("two_factor_disabled_at")

  // Relations
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  files        File[]
  conflicts    Conflict[]
  sharedLinks  SharedLink[]  @relation("UserSharedLinks")
  tokens       Token[]
  oauthTokens   OAuthToken[]
  userRemotes  UserRemote[]
  vpsConnections VpsConnection[]
  cloudConfigs CloudConfig[]
  auditLogs    AuditLog[]

  @@index([email])
  @@index([tenantId])
  @@map("users")
}

model File {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  tenantId      String?   @map("tenant_id") @default("00000000-0000-0000-0000-000000000001")
  path          String
  sizeBytes     BigInt    @map("size_bytes")
  hash          String?
  status        String    @default("pending")
  lastModified  DateTime? @map("last_modified")
  syncedAt      DateTime? @map("synced_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  sharedLinks   SharedLink[]

  @@unique([userId, path])
  @@index([userId, path])
  @@index([userId, status])
  @@index([lastModified(sort: Desc)])
  @@map("files")
}

model SharedLink {
  id            String    @id @default(uuid())
  fileId        String    @map("file_id")
  token         String    @unique
  passwordHash  String?   @map("password_hash")
  expiresAt     DateTime? @map("expires_at")
  maxDownloads  Int?      @map("max_downloads")
  downloadCount Int       @default(0) @map("download_count")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdByUser User      @relation("UserSharedLinks", fields: [createdBy], references: [id])

  @@index([token])
  @@map("shared_links")
}

model Conflict {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  tenantId        String?   @map("tenant_id") @default("00000000-0000-0000-0000-000000000001")
  filePath        String    @map("file_path")
  localVersionUrl String?   @map("local_version_url")
  cloudVersionUrl String?   @map("cloud_version_url")
  resolved        Boolean   @default(false)
  resolutionType  String?   @map("resolution_type")
  detectedAt      DateTime  @default(now()) @map("detected_at")
  resolvedAt      DateTime? @map("resolved_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([userId, resolved])
  @@map("conflicts")
}

model CloudConfig {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  provider    String
  configJson  String    @map("config_json")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cloud_configs")
}

model AdminNotification {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id") @default("00000000-0000-0000-0000-000000000001")
  type      String
  message   String
  payload   Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([read])
  @@index([type])
  @@map("admin_notifications")
}

// Token Vault (AUTH-2, VAULT-1)
model Token {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  provider            String
  encryptedCredentials Bytes    @map("encrypted_credentials")
  encryptionVersion   Int       @default(1) @map("encryption_version")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @map("updated_at")
  expiresAt           DateTime? @map("expires_at")
  isActive            Boolean   @default(true) @map("is_active")

  // Multi-account support (max 3 per provider)
  accountLabel        String    @default("Primary") @map("account_label")
  accountOrder        Int       @default(1) @map("account_order")
  isDefault           Boolean   @default(false) @map("is_default")

  // Metadata
  remoteId            String?   @map("remote_id")
  lastUsedAt          DateTime? @map("last_used_at")
  migratedAt          DateTime? @map("migrated_at")

  // Relations
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, accountLabel])
  @@index([userId])
  @@index([provider])
  @@index([userId, provider])
  @@index([userId, provider, accountOrder])
  @@index([isActive])
  @@map("tokens")
}

// OAuth Tokens (AUTH-1)
model OAuthToken {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  provider          String
  providerAccountId String?   @map("provider_account_id")
  accessToken       String    @map("access_token")
  refreshToken      String?   @map("refresh_token")
  expiresAt         DateTime? @map("expires_at")
  scope             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")

  // Multi-account support
  accountLabel      String    @default("Primary") @map("account_label")
  accountOrder      Int       @default(1) @map("account_order")
  isDefault         Boolean   @default(false) @map("is_default")
  migratedAt        DateTime? @map("migrated_at")

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, providerAccountId])
  @@index([userId])
  @@index([expiresAt])
  @@index([userId, provider, accountOrder])
  @@map("oauth_tokens")
}

// User Remotes (server-side credential persistence)
model UserRemote {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  provider          String
  accountKey        String    @map("account_key")
  accountId         String?   @map("account_id")
  accountEmail      String?   @map("account_email")
  displayName       String?   @map("display_name")
  accessTokenEnc    String    @map("access_token_enc")
  refreshTokenEnc   String?   @map("refresh_token_enc")
  expiresAt         DateTime? @map("expires_at")
  disabled          Boolean   @default(false)
  keyVersion        String    @default("1") @map("key_version")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastUsedAt        DateTime? @map("last_used_at")

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, accountKey])
  @@index([userId, provider])
  @@index([userId, provider, accountKey])
  @@map("user_remotes")
}

model VpsConnection {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  label      String
  host       String
  port       Int      @default(22)
  username   String
  authMethod String   @default("pem") @map("auth_method")
  pemKey     Bytes    @map("pem_key")
  pemIv      Bytes    @map("pem_iv")
  lastTestedAt DateTime? @map("last_tested_at")
  lastHostFingerprint String? @map("last_host_fingerprint")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, host, username])
  @@map("vps_connections")
}

// Audit Logs (TRANSFER-1)
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  resource    String   // 'file', 'share', 'conflict', 'auth'
  resourceId  String?  @map("resource_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([resourceId])
  @@map("audit_logs")
}

// Transfer History (TRANSFER-1)
// Note: Active transfers use BullMQ/Redis, this is for history/persistence
model Transfer {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  sourceProvider  String    @map("source_provider")
  destProvider    String    @map("dest_provider")
  fileId          String    @map("file_id")
  fileName        String    @map("file_name")
  fileSize        BigInt    @map("file_size")
  operation       String    // 'copy', 'move', 'upload', 'download'
  status          String    @default("pending") // 'pending', 'running', 'completed', 'failed', 'cancelled'
  progress        Int       @default(0)
  
  sourceFolderId  String?   @map("source_folder_id")
  destFolderId   String?   @map("dest_folder_id")
  
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("transfers")
}

// Rate Limiting (TRANSFER-1)
model RateLimit {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  provider    String
  action      String   // 'download', 'upload', 'list', etc.
  count       Int      @default(0)
  windowStart DateTime @map("window_start")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, provider, action, windowStart])
  @@index([userId, provider])
  @@map("rate_limits")
}

model ScheduledJob {
  id              String    @id
  name            String
  jobType         String    @map("job_type")
  cronExpression  String    @map("cron_expression")
  enabled         Boolean   @default(true)
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  metadata        Json?     @map("metadata")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([nextRunAt])
  @@index([enabled])
  @@map("scheduled_jobs")
}
