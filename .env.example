# Long-running runtime target required for SSE-1 and TRANSFER-1.
# Do not use serverless/edge targets (vercel, netlify, lambda, cloudflare workers).
DEPLOYMENT_TARGET=docker

# Linear CLI (linearis)
LINEAR_API_TOKEN=                  # Personal API token from linear.app/settings/api

# CodeRabbit CLI
CODERABBIT_API_KEY=                # From app.coderabbit.ai/profile

# Orchestration automation
DATACENTER=oci                    # "oci" (primary) or "india" (worker-only)
GITHUB_WEBHOOK_SECRET=            # Shared secret for CodeRabbit webhook HMAC verification
LINEAR_TEAM_KEY=CF                # Default Linear team key for issue creation
GH_TOKEN=                         # GitHub CLI token for gh pr create
